# PiecesOfLife production configuration.
# Copy to .env next to docker-compose.yml and fill in. Never commit .env.

# --- Core ------------------------------------------------------------
# Public URL members will open — used in every email link.
BASE_URL=https://letters.example.com
# Host port to expose (the container listens on the same port).
PORT=8080
# The first admin account, created on first boot.
ADMIN_EMAIL=you@example.com
# Long random string; signs the CSRF cookies. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# --- Email delivery ---------------------------------------------------
# "smtp" (any classic provider) or "jmap" (Fastmail API token —
# see docs/fastmail-jmap.md for a full walkthrough).
EMAIL_PROVIDER=jmap

# Sender. FROM_EMAIL must be an address you're allowed to send as
# (for Fastmail: one of your sending identities). FROM_NAME is the
# display name next to it in inboxes — usually your circle's name.
FROM_EMAIL=letters@example.com
FROM_NAME=

# JMAP (required when EMAIL_PROVIDER=jmap)
JMAP_SESSION_URL=https://api.fastmail.com/jmap/session
JMAP_API_TOKEN=

# SMTP (required when EMAIL_PROVIDER=smtp; implicit TLS, port 465)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# --- Logging ----------------------------------------------------------
LOG_LEVEL=info
